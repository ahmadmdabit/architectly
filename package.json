{
  "name": "architectly",
  "description": "Architectly interviews you step by step — asking the right questions in the right order — then assembles a structured requirements document aligned with industry best practices.",
  "author": "Ahmet Fatihoglu",
  "license": "MIT",
  "homepage": "https://ahmadmdabit.github.io/architectly",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "asset-hash-refresh": "node scripts/asset-hash-refresh.mjs",
    "dev": "vite",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && yarn asset-hash-refresh && vite build",
    "preview": "vite preview",
    "predeploy": "yarn build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@fontsource/cairo": "^5.2.7",
    "@heyputer/puter.js": "^2.5.3",
    "docx": "^9.7.1",
    "dompurify": "^3.4.11",
    "globals": "^17.6.0",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^4.0.0",
    "jspdf": "^4.2.1",
    "marked": "^18.0.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.21",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^10.5.0",
    "gh-pages": "^6.3.0",
    "sass-embedded": "^1.100.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "yarn@4.17.0"
}
